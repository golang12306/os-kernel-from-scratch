#!/usr/bin/env bpftrace
// ebpf/hello.bt — 追踪所有 open/openat 系统调用
// 用法: sudo bpftrace hello.bt

BEGIN
{
    printf("Tracing open/openat syscalls... Hit Ctrl-C to end.\n");
    printf("%-16s %-6s %s\n", "COMM", "PID", "FILE");
}

// 追踪 enter 点（参数还没执行）
tracepoint:syscalls:sys_enter_open,
tracepoint:syscalls:sys_enter_openat
{
    printf("%-16s %-6d %s\n", comm, pid, args->filename);
}
